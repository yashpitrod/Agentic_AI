# API Keys
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# GitHub Integration
GITHUB_TOKEN=your-github-personal-access-token-here
GITHUB_WEBHOOK_SECRET=change-me-local-secret

# MongoDB (replaces SQLite — create free cluster at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# GitHub OAuth App (for repo connection — create at github.com/settings/applications/new)
GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret

# Google OAuth (for user login — create at console.cloud.google.com → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# URLs
FRONTEND_URL=http://localhost:5173
WEBHOOK_URL=http://localhost:8000
