# API Keys
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# GitHub Integration
GITHUB_TOKEN=your-github-personal-access-token-here
GITHUB_WEBHOOK_SECRET=change-me-local-secret

# SQLite persistence
REVIEWS_DB_PATH=reviews.db
# Render persistent disk example:
# REVIEWS_DB_PATH=/var/data/reviews.db

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# GitHub OAuth App (separate from webhook — create at github.com/settings/applications/new)
GITHUB_CLIENT_ID=your-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-oauth-app-client-secret
FRONTEND_URL=http://localhost:5173
WEBHOOK_URL=http://localhost:8000
